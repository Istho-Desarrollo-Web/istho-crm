{
  "info": {
    "_postman_id": "istho-wms-centhrix-v1",
    "name": "ISTHO WMS CenthriX",
    "description": "Colección completa de la API REST ISTHO WMS CenthriX.\n\nVariables a configurar antes de usar:\n- base_url: URL base del WMS (por defecto producción)\n- wms_email / wms_password: credenciales de integración\n\nFlujo recomendado: ejecutar 'Login' primero — el script guarda access_token y refresh_token automáticamente en las variables de colección.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",      "value": "https://apiistho.cinnco.co/api/v1", "type": "string" },
    { "key": "access_token",  "value": "", "type": "string" },
    { "key": "refresh_token", "value": "", "type": "string" },
    { "key": "wms_email",     "value": "admin@empresa.com", "type": "string" },
    { "key": "wms_password",  "value": "", "type": "string" },
    { "key": "order_id",      "value": "", "type": "string" },
    { "key": "pallet_id",     "value": "", "type": "string" },
    { "key": "warehouse_id",  "value": "", "type": "string" },
    { "key": "product_id",    "value": "", "type": "string" },
    { "key": "customer_id",   "value": "", "type": "string" },
    { "key": "zone_id",       "value": "", "type": "string" },
    { "key": "rack_id",       "value": "", "type": "string" },
    { "key": "position_id",   "value": "", "type": "string" },
    { "key": "level_id",      "value": "", "type": "string" },
    { "key": "module_id",     "value": "", "type": "string" },
    { "key": "label_id",      "value": "", "type": "string" },
    { "key": "forklift_id",   "value": "", "type": "string" },
    { "key": "pallet_code",   "value": "", "type": "string" },
    { "key": "position_code", "value": "", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }]
  },
  "item": [

    {
      "name": "1. Auth",
      "item": [
        {
          "name": "Login",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "if (pm.response.code === 200) {",
                "  const r = pm.response.json();",
                "  const data = r.data || r;",
                "  pm.collectionVariables.set('access_token', data.accessToken);",
                "  pm.collectionVariables.set('refresh_token', data.refreshToken);",
                "  console.log('Tokens guardados correctamente');",
                "}"
              ]
            }
          }],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{wms_email}}\",\n  \"password\": \"{{wms_password}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            },
            "description": "Público — sin JWT. Guarda access_token y refresh_token en variables de colección."
          },
          "response": []
        },
        {
          "name": "Get Perfil (Me)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/auth/me",
              "host": ["{{base_url}}"],
              "path": ["auth", "me"]
            },
            "description": "Retorna el perfil del usuario autenticado."
          },
          "response": []
        },
        {
          "name": "Refresh Token",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "if (pm.response.code === 200) {",
                "  const r = pm.response.json();",
                "  const data = r.data || r;",
                "  pm.collectionVariables.set('access_token', data.accessToken);",
                "  pm.collectionVariables.set('refresh_token', data.refreshToken);",
                "  console.log('Tokens renovados correctamente');",
                "}"
              ]
            }
          }],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refresh_token}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/auth/refresh",
              "host": ["{{base_url}}"],
              "path": ["auth", "refresh"]
            },
            "description": "Público. Renueva el par de tokens usando el refreshToken."
          },
          "response": []
        }
      ]
    },

