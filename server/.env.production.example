# =====================================================
# ISTHO CRM - Variables de Entorno (Producción - Railway)
# =====================================================
# Configurar estas variables en el dashboard de Railway
# NO subir este archivo con valores reales al repositorio

# Ambiente
NODE_ENV=production
PORT=5000
API_PREFIX=/api/v1

# Base de datos MySQL (Railway provee estas variables automáticamente)
# Opción 1: URL de conexión (preferida - Railway la genera automáticamente)
MYSQL_URL=${{MySQL.MYSQL_URL}}

# Opción 2: Variables individuales (alternativa)
DB_HOST=${{MySQL.MYSQLHOST}}
DB_PORT=${{MySQL.MYSQLPORT}}
DB_NAME=${{MySQL.MYSQLDATABASE}}
DB_USER=${{MySQL.MYSQLUSER}}
DB_PASSWORD=${{MySQL.MYSQLPASSWORD}}
DB_LOGGING=false
DB_POOL_MAX=5
DB_POOL_MIN=0
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# JWT - Autenticación (GENERAR un secreto seguro)
# Ejemplo: openssl rand -base64 64
JWT_SECRET=GENERAR_SECRETO_SEGURO_AQUI
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Email SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu_email@gmail.com
SMTP_PASS=tu_app_password
EMAIL_FROM=ISTHO CRM <notificaciones@istho.com.co>

# Upload de archivos
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760
ALLOWED_EXTENSIONS=.pdf,.doc,.docx,.xls,.xlsx,.jpg,.jpeg,.png

# WMS Copérnico
WMS_API_URL=https://api.copernico.sgv.com
WMS_API_KEY=
WMS_API_SECRET=

# Seguridad - CORS (URL del frontend en Vercel)
CORS_ORIGIN=https://tu-app.vercel.app
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log
