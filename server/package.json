{
  "name": "istho-crm-backend",
  "version": "1.0.0",
  "description": "Backend API para el CRM interno de ISTHO S.A.S.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --forceExit",
    "test:coverage": "jest --coverage",
    "migration:create": "node src/scripts/createMigration.js",
    "migration:status": "node src/scripts/runMigrations.js status",
    "migration:up": "node src/scripts/runMigrations.js up",
    "migration:undo": "node src/scripts/runMigrations.js undo",
    "db:seed": "npx sequelize-cli db:seed:all",
    "db:seed:undo": "npx sequelize-cli db:seed:undo:all",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/"
  },
  "keywords": [
    "istho",
    "crm",
    "logistica",
    "express",
    "api"
  ],
  "author": "ISTHO S.A.S. - Coordinación TI",
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1038.0",
    "@aws-sdk/s3-request-presigner": "^3.1038.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "archiver": "^7.0.1",
    "axios": "^1.15.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "express-validator": "^7.0.1",
    "handlebars": "^4.7.8",
    "helmet": "^7.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "mysql2": "^3.6.5",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.5",
    "otplib": "^13.4.0",
    "pdfkit": "^0.17.2",
    "qrcode": "^1.5.4",
    "resend": "^6.9.4",
    "sequelize": "^6.35.2",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "umzug": "^3.8.2",
    "uuid": "^9.0.1"
  },
  "jest": {
    "globalSetup": "./src/tests/globalSetup.js",
    "testEnvironment": "node",
    "testTimeout": 30000,
    "setupFilesAfterEnv": [
      "./src/tests/setup.js"
    ],
    "testMatch": [
      "**/src/tests/**/*.test.js"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(@scure|@noble|@otplib)/)"
    ],
    "collectCoverageFrom": [
      "src/controllers/**/*.js",
      "src/services/**/*.js",
      "src/middleware/**/*.js",
      "!src/scripts/**",
      "!src/migrations/**"
    ]
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@eslint/js": "^9.39.4",
    "babel-jest": "^30.3.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.5.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.8.3",
    "sequelize-cli": "^6.6.2",
    "supertest": "^6.3.3"
  }
}
