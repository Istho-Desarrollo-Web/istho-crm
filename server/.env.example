# =====================================================
# ISTHO CRM - Variables de Entorno (Desarrollo)
# =====================================================
# Copiar este archivo como .env y completar los valores

# Ambiente
NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1

# Base de datos (XAMPP por defecto)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=istho_crm
DB_USER=root
DB_PASSWORD=
DB_LOGGING=true
DB_POOL_MAX=20
DB_POOL_MIN=0
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# JWT - Autenticación (CAMBIAR en producción)
JWT_SECRET=cambiar_este_secreto_en_produccion
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Email SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu_email@gmail.com
SMTP_PASS=tu_app_password_aqui
EMAIL_FROM=ISTHO CRM <notificaciones@istho.com.co>

# Amazon S3 — almacenamiento de archivos
AWS_S3_BUCKET=istho-crm-files
AWS_REGION=us-west-2
# En producción (App Runner): usar IAM Instance Role, NO poner credenciales aquí.
# En desarrollo local: configurar AWS CLI (aws configure) o poner las claves abajo:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Logo para emails (debe ser URL pública — S3, CloudFront, etc.)
# LOGO_EMAIL_URL=https://istho-crm-files.s3.us-west-2.amazonaws.com/branding/logo-email.png

# Redis — adaptador multi-instancia para Socket.IO (opcional pero recomendado en producción)
# Recomendado: Upstash Redis (upstash.com) — gratis, sin VPC, solo pegar la URL
# REDIS_URL=rediss://default:<password>@<host>.upstash.io:6379

# WMS Centhrix (configurar después)
WMS_API_URL=https://api.copernico.sgv.com
WMS_API_KEY=
WMS_API_SECRET=

# URL de la app (para botones en emails)
APP_URL=http://localhost:5173

# Seguridad
CORS_ORIGIN=http://localhost:5173
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=500

# Logging
LOG_LEVEL=debug
LOG_FILE=./logs/app.log

# Contraseñas de usuarios seed (CAMBIAR en producción)
SEED_PASSWORD_ADMIN=Admin2026*
SEED_PASSWORD_SUPERVISOR=Supervisor2026*
SEED_PASSWORD_OPERADOR=Operador2026*

# Redis (opcional, recomendado para Socket.IO en producción)
REDIS_URL=redis://default:password@host:6379