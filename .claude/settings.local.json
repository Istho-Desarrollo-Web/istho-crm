{
  "env": {
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "50000",
    "DISABLE_NON_ESSENTIAL_MODEL_CALLS": "1",
    "DISABLE_COST_WARNINGS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(node .agents/skills/impeccable/scripts/cleanup-deprecated.mjs)",
      "Bash(git add *)",
      "Bash(git commit -m ' *)",
      "Bash(git worktree *)",
      "Bash(npm install *)",
      "Bash(node *)",
      "Bash(npm run *)",
      "Bash(npx eslint *)",
      "Bash(npx prettier *)",
      "Bash(cd frontend && npm run *)",
      "Bash(cd server && npm run *)",
      "Bash(powershell -Command ' *)",
      "Bash(grep -c \"^\" frontend/src/index.css)",
      "Bash(wc -c frontend/src/index.css)",
      "Bash(powershell *)",
      "Bash(git commit *)",
      "Bash(tee eslint-output.txt)",
      "Bash(git branch *)",
      "Bash(echo \"exit:$?\")",
      "Bash(echo \"Exit code: $?\")",
      "Skill(update-docs)",
      "Bash(git stash *)",
      "Bash(git checkout *)",
      "Bash(grep -v \"//\")",
      "Bash(grep -v \"node_modules\\\\|\\\\.bak\\\\|//\")",
      "WebSearch",
      "Bash(find c:\\\\\\\\Users\\\\\\\\PC_PRACTIDS\\\\\\\\Documents\\\\\\\\GitHub\\\\\\\\istho-crm-p\\\\\\\\server\\\\\\\\src -name \"*security*\" -o -name \"*auth*\")"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "f=$(jq -r '.tool_input.file_path // empty' 2>/dev/null); [ -z \"$f\" ] && exit 0; case \"$f\" in *.jsx|*.js|*.mjs) true;; *) exit 0;; esac; if echo \"$f\" | grep -qi 'frontend.src'; then out=$(cd 'c:/Users/PC_PRACTIDS/Documents/GitHub/istho-crm-p/frontend' && npx eslint \"$f\" --no-color 2>&1); elif echo \"$f\" | grep -qi 'server.src'; then out=$(cd 'c:/Users/PC_PRACTIDS/Documents/GitHub/istho-crm-p/server' && npx eslint \"$f\" --no-color 2>&1); else exit 0; fi; if [ -n \"$out\" ]; then jq -cn --arg ctx \"ESLint detectó problemas:\\n$out\" '{\"hookSpecificOutput\":{\"hookEventName\":\"PostToolUse\",\"additionalContext\":$ctx}}'; fi; exit 0",
            "timeout": 30,
            "statusMessage": "Verificando estándares ESLint..."
          }
        ]
      }
    ]
  }
}
