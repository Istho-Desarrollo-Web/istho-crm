# =====================================================
# ISTHO CRM Frontend - Variables de Entorno (Producción - Vercel)
# =====================================================
# Configurar estas variables en el dashboard de Vercel
# Settings > Environment Variables

# API - URL del backend en Railway
VITE_API_URL=https://tu-backend.up.railway.app/api/v1
VITE_API_TIMEOUT=30000

# App
VITE_APP_NAME=ISTHO CRM
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=Sistema CRM Interno ISTHO S.A.S.

# File Upload
VITE_MAX_FILE_SIZE=10485760
VITE_ALLOWED_FILE_TYPES=.pdf,.doc,.docx,.xls,.xlsx,.jpg,.jpeg,.png

# Feature Flags
VITE_ENABLE_DARK_MODE=true
VITE_ENABLE_NOTIFICATIONS=true

# WMS Integration
VITE_WMS_API_URL=
VITE_WMS_SYNC_INTERVAL=300000
