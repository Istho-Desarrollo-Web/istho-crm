# API Configuration
VITE_API_URL=http://localhost:5000/api/v1, http://192.168.1.6:5173/api/v1
VITE_API_TIMEOUT=30000

# App Configuration
VITE_APP_NAME=ISTHO CRM
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=Sistema CRM Interno ISTHO S.A.S.

# File Upload
VITE_MAX_FILE_SIZE=10485760
VITE_ALLOWED_FILE_TYPES=.pdf,.doc,.docx,.xls,.xlsx,.jpg,.jpeg,.png

# Feature Flags
VITE_ENABLE_DARK_MODE=true
VITE_ENABLE_NOTIFICATIONS=true

# WMS Integration (Fase futura)
VITE_WMS_API_URL=
VITE_WMS_SYNC_INTERVAL=300000

# Microservicio de Impresión (centhrix-print-server, LAN local)
# URL del servidor de impresión en la red local de la bodega
VITE_PRINT_SERVER_URL=http://192.168.1.100:3000
# API Key externa generada desde la UI admin del print server
VITE_PRINT_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx